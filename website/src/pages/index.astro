---
import "../styles/global.css";
import "../styles/inheritance.css";

const base = import.meta.env.BASE_URL;
const repo = "https://github.com/fyapeng/junzi-economist-skill";
const layers = [
  ["道", "DAO", "立其问", "什么值得研究？", "真实的人、制度、物质条件、分配后果与人的发展"],
  ["法", "FA", "明其理", "经济对象怎样运行？", "主体、约束、信息、激励、互动、均衡、动态与福利"],
  ["势", "SHI", "察其实", "具体情势怎样？", "历史阶段、制度执行、市场边界、数据生成与学术前沿"],
  ["术", "SHU", "构其模", "怎样形成可信研究？", "结构建模、证据识别、估计、反事实、验证与回溯"],
  ["器", "QI", "驭其用", "借助什么完成？", "数据、文献、软件、算法、求解器与计算设施"],
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="君子经济学家：以理论建立结构、以证据约束模型的开放型 Codex 经济学研究伙伴。" />
    <meta name="theme-color" content="#f3ecdf" />
    <link rel="icon" type="image/svg+xml" href={`${base}economist-mark.svg`} />
    <title>君子经济学家 · Junzi Economist</title>
  </head>
  <body>
    <header>
      <a class="brand" href={base}><span>经</span><b>君子经济学家<small>JUNZI ECONOMIST</small></b></a>
      <nav><a href="#inheritance">继承</a><a href="#hierarchy">五层</a><a href="#evidence">证据</a><a href="#install">安装</a></nav>
      <a class="github" href={repo}>GitHub ↗</a>
    </header>

    <main>
      <section class="hero shell">
        <div class="hero-copy">
          <p class="eyebrow"><i></i> THEORY · STRUCTURE · EVIDENCE</p>
          <h1>以理论<br /><em>建立结构</em></h1>
          <p class="lead">承接君子人格与实践纪律，从真实经济问题出发，以理论和制度建立结构模型，让事实与简约式证据识别、约束并检验它，进而研究均衡、福利与政策反事实。</p>
          <div class="actions"><a class="primary" href="#evidence">查看研究次序</a><a href={`${repo}/blob/main/skills/junzi-economist/SKILL.md`}>阅读技能核心 ↗</a></div>
          <p class="traits">问题意识 · 结构建模 · 证据识别 · 人文关怀 · 实践修正</p>
        </div>
        <div class="hero-figure" aria-label="研究路径图">
          <div class="seal"><span>经</span><small>ECONOMIST</small></div>
          <svg viewBox="0 0 520 520" aria-hidden="true"><circle cx="260" cy="260" r="205"/><circle cx="260" cy="260" r="148"/><path d="M103 336C165 230 225 302 282 195S402 155 430 208"/><path d="M104 380h326"/></svg>
          <div class="figure-note"><b>经世济民</b><span>理论建立结构，证据决定可信边界</span></div>
        </div>
      </section>

      <section id="inheritance" class="inheritance">
        <div class="shell inheritance-grid">
          <div><p class="eyebrow"><i></i> ONE SYSTEM · TWO LEVELS</p><h2>君子立其本<br /><em>经济学明其用</em></h2><p>君子经济学家承接完整 Junzi 的人格、主线、主要矛盾、独立判断、分支回溯与工具纪律，并把它们专门化为经济理论、制度调查、证据、估计、福利与写作。</p></div>
          <div class="inheritance-map">
            <article><span>上层</span><b>Junzi · 君子</b><small>道与一般实践纪律</small></article>
            <i>↓　领域专门化</i>
            <article class="economist"><span>下层</span><b>Junzi Economist</b><small>经济理论与研究判断</small></article>
            <i>↓　随任务求知</i>
            <p>领域理论 · 制度事实 · 前沿证据 · 方法与工具</p>
          </div>
        </div>
      </section>

      <section id="hierarchy" class="hierarchy">
        <div class="shell">
          <div class="heading"><p class="eyebrow"><i></i> DAO · FA · SHI · SHU · QI</p><h2>五层相生<br /><em>由内而外形成研究能力</em></h2></div>
          <div class="layers">
            {layers.map(([key, latin, title, question, text], i) => <article style={`--i:${i}`}><span class="number">0{i+1}</span><div class="round">{key}</div><p>{latin}</p><h3>{title}</h3><b>{question}</b><small>{text}</small></article>)}
          </div>
        </div>
      </section>

      <section id="evidence" class="evidence shell">
        <div class="heading"><p class="eyebrow"><i></i> STRUCTURAL RESEARCH</p><h2>结构有主线<br /><em>模型接受证据约束</em></h2><p>理论和制度提出结构，事实与简约式证据识别并检验它，估计服务于均衡、福利和政策反事实。</p></div>
        <div class="evidence-path">
          <article><span>01</span><b>经济问题</b><small>谁在何种约束下作出什么选择，后果由谁承担？</small></article>
          <article><span>02</span><b>理论与制度</b><small>哪些机制竞争，制度怎样改变激励、信息与均衡？</small></article>
          <article class="focus"><span>03</span><b>结构模型</b><small>明确主体、状态、时序、原语、互动、均衡与政策目标。</small></article>
          <article><span>04</span><b>证据与识别</b><small>用事实和简约式变异约束机制、参数、矩与支持范围。</small></article>
          <article><span>05</span><b>估计与反事实</b><small>整合证据，检验模型，研究均衡、福利与政策结果。</small></article>
        </div>
        <div class="equation"><span>问题</span><i>→</i><span>理论制度</span><i>→</i><strong>结构模型</strong><i>→</i><span>证据约束</span><i>→</i><span>反事实与福利</span></div>
      </section>

      <section id="learning" class="roles">
        <div class="shell roles-layout">
          <div class="heading light"><p class="eyebrow"><i></i> OPEN LEARNING</p><h2>根基保持稳定<br /><em>知识随问题生长</em></h2><p>技能保存通用的经济学思维，并为当前任务建立最小充分的知识模型。</p></div>
          <div class="role-cards">
            <article><p>01 · LOCATE</p><h3>定位缺口</h3><span>辨认当前缺少理论、制度、事实、测量、识别或计算</span><b>让真实问题决定学习方向</b></article>
            <article><p>02 · SEARCH</p><h3>开放检索</h3><span>连接经典、前沿原始研究、官方材料、竞争观点与相邻学科</span><b>新近与权威都要接受比较</b></article>
            <article><p>03 · SYNTHESIZE</p><h3>经济学综合</h3><span>重建主体、约束、信息、互动、均衡、分配与福利</span><b>资料只有进入机制才能形成判断</b></article>
            <article><p>04 · REVISE</p><h3>实践修正</h3><span>用辨别性证据检验路径，保留所得，必要时回到上层换路</span><b>个案经验不轻率固化为普遍规则</b></article>
          </div>
        </div>
      </section>

      <section class="mainline shell">
        <div class="mainline-copy"><p class="eyebrow"><i></i> ACTIVE RESEARCH STATE</p><h2>档案保存经验<br /><em>不接管现在</em></h2><p>最新明确目标、根目录状态和当前研究主线决定正在推进什么。旧稿、归档、历史输出与废弃模型可供追索，却不会凭数量、日期或技术复杂度自动复活。</p></div>
        <div class="state-board"><div><b>当前主线</b><span>目标 · 状态 · 计划</span></div><div><b>项目记忆</b><span>旧稿 · 输出 · 失败分支</span></div><p>篇幅更多　·　更新更晚　·　技术更复杂<br /><strong>≠ 当前路线</strong></p></div>
      </section>

      <section id="install" class="install">
        <div class="shell install-grid"><div><p class="eyebrow"><i></i> BEGIN THE PRACTICE</p><h2>先立君子之本<br /><em>再成经济学之用</em></h2><p>完整配置依次安装 Junzi 与 Junzi Economist。两者进入同一任务后分层协作，不重复宪章和检查清单。</p></div><div class="terminal"><p>从 GitHub 安装完整双层系统</p><code><span>npx -y skills add fyapeng/junzi-skill --skill junzi -g -a codex --copy -y</span><span>npx -y skills add fyapeng/junzi-economist-skill --skill junzi-economist -g -a codex --copy -y</span></code><div><a href={repo}>查看 GitHub 仓库</a><a href={`${repo}/blob/main/README.md#安装`}>其他安装方式 ↗</a></div></div></div>
      </section>
    </main>

    <footer><div class="footer-mark">经</div><p>从现实问题出发，以理论建立结构，以证据约束模型；研究均衡、福利与政策，在实践中修正。</p><div>© 2026 fyapeng　<a href={repo}>GitHub</a>　Apache 2.0</div></footer>
  </body>
</html>
